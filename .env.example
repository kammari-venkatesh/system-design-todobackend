# MongoDB Atlas connection string
MONGO_URI=mongodb+srv://USERNAME:PASSWORD@cluster.mongodb.net/system_design?retryWrites=true&w=majority

# Auth — use a long random string in production
JWT_SECRET=change-this-to-a-long-random-secret

# Server
PORT=5000
NODE_ENV=development

# Comma-separated frontend origins for CORS (optional in production — defaults to https://*.vercel.app)
# Example: https://your-app.vercel.app
FRONTEND_URL=http://localhost:5173

# Public backend URL for absolute upload links (auto-set on Render via RENDER_EXTERNAL_URL)
# Production: https://system-design-todobackend-1.onrender.com
PUBLIC_URL=http://localhost:5000
